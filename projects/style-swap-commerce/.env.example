# Server Configuration
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/styleswap_commerce

# Stripe
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Affiliate Partners
AFFILIATE_WEBHOOK_SECRET=your_webhook_secret_here

# UTM Tracking
DEFAULT_UTM_SOURCE=styleswap
DEFAULT_UTM_MEDIUM=referral

# Commission Rates (in percentage)
DEFAULT_COMMISSION_RATE=10
BRAND_COMMISSION_RATES={"nike":12,"adidas":10,"zara":8}

# Analytics
ANALYTICS_RETENTION_DAYS=365

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3001
