# ─── Junction Media — Environment Variables ──────────────────────────────────
# Copy to .env.local for local dev
# Set in Vercel Dashboard > Settings > Environment Variables for production

# ─── Analytics ────────────────────────────────────────────────────────────────
# Google Analytics 4 Measurement ID
# Get from: analytics.google.com > Admin > Data Streams > Web stream > Measurement ID
NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX

# ─── (Future) Contact Form Email ──────────────────────────────────────────────
# Resend API Key — for server-side contact/apply form submissions
# Get from: resend.com/api-keys
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# ─── (Future) CRM / Lead Capture ─────────────────────────────────────────────
# HubSpot Portal ID
# NEXT_PUBLIC_HUBSPOT_PORTAL_ID=xxxxxxxxx
