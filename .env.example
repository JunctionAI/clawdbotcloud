# ========================================
# CONTENT MONETIZATION SYSTEM - ENV CONFIG
# ========================================
#
# Copy this file to .env and fill in your credentials
# Keep .env private - never commit to git!
#

# ========================================
# AI CONTENT GENERATION
# ========================================
# Get OpenAI key: https://platform.openai.com/api-keys
# Or Anthropic key: https://console.anthropic.com/
# You only need ONE of these

OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# ========================================
# TWITTER / X
# ========================================
# Get credentials: https://developer.twitter.com/
# Required: API Key, API Secret, Access Token, Access Secret

TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# ========================================
# LINKEDIN
# ========================================
# Get credentials: https://www.linkedin.com/developers/
# Required: Access Token, User ID

LINKEDIN_ACCESS_TOKEN=
LINKEDIN_USER_ID=

# ========================================
# WORDPRESS
# ========================================
# Your WordPress site URL and credentials
# Uses WordPress REST API

WORDPRESS_URL=https://yourblog.com
WORDPRESS_USERNAME=
WORDPRESS_PASSWORD=

# ========================================
# MEDIUM
# ========================================
# Get token: https://medium.com/me/settings
# Integration tokens section

MEDIUM_TOKEN=

# ========================================
# GOOGLE ADSENSE (Optional)
# ========================================
# For tracking ad revenue in analytics

ADSENSE_CLIENT_ID=
ADSENSE_CLIENT_SECRET=

# ========================================
# CONVERTKIT / EMAIL (Optional)
# ========================================
# For newsletter automation

CONVERTKIT_API_KEY=
CONVERTKIT_API_SECRET=

# ========================================
# ANALYTICS (Optional)
# ========================================
# For enhanced analytics tracking

GOOGLE_ANALYTICS_ID=
GOOGLE_SEARCH_CONSOLE_SITE=

# ========================================
# WEBHOOKS (Optional)
# ========================================
# For notifications when revenue events happen

SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=

# ========================================
# NOTES
# ========================================
#
# Priority setup (in order):
# 1. OPENAI_API_KEY or ANTHROPIC_API_KEY (for content generation)
# 2. WORDPRESS_URL (for blog publishing)
# 3. TWITTER credentials (for social automation)
# 4. Everything else is optional
#
# Start with just AI key and build from there!
