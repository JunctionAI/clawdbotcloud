    "stocks": {
      "enabled": true,
      "symbols": ["AAPL", "MSFT", "GOOGL", "NVDA", "SPY", "QQQ"],
      "nzStocks": ["FPH.NZ", "AIA.NZ", "SPK.NZ", "MEL.NZ"],
