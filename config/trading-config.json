    },
    "alpaca": {
      "apiKey": "YOUR_ALPACA_API_KEY",
      "apiSecret": "YOUR_ALPACA_API_SECRET",
      "paper": true,
      "baseUrl": "https://paper-api.alpaca.markets"
    },
    "polygon": {
      "apiKey": "YOUR_POLYGON_API_KEY"
    },
    "coingecko": {
      "apiKey": "YOUR_COINGECKO_API_KEY"
    }
  },
  "portfolio": {
    "paperBalance": {
      "USD": 50000,
      "USDT": 20000,
      "NZD": 30000
    },
    "riskPerTrade": 0.02,
    "maxPositions": 10,
    "maxDrawdown": 0.15
